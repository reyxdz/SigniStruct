MONGODB_URI=mongodb://localhost:27017/signistruct
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_key_hereMASTER_ENCRYPTION_KEY=your-32-character-encryption-key-here
JWT_EXPIRY=7d

# PDF Upload Configuration (PDF-only documents)
DOCUMENT_UPLOAD_DIR=./uploads/documents
TEMP_UPLOAD_DIR=./uploads/temp
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=pdf